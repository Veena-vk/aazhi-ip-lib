{
  "id": "i2c_master",
  "name": "I2C Master Controller",
  "version": "1.0.0",
  "category": "protocols",
  "subcategory": "serial",
  "description": "Full-featured I2C master with AXI4-Stream command and data interface. Supports repeated starts, multi-byte transfers, clock stretching, and missed-ACK detection.",
  "author": "Alex Forencich",
  "author_url": "https://github.com/alexforencich",
  "source_url": "https://github.com/alexforencich/verilog-i2c",
  "source_file_url": "https://raw.githubusercontent.com/alexforencich/verilog-i2c/master/rtl/i2c_master.v",
  "license": "MIT",
  "language": "Verilog 2001",
  "rtl_files": [
    "rtl/i2c_master.v"
  ],
  "top_modules": [
    "i2c_master"
  ],
  "fetch_on_use": true,
  "parameters": [
    {
      "name": "prescale",
      "type": "port",
      "description": "I2C clock prescaler = clk / (FI2C * 4)"
    },
    {
      "name": "stop_on_idle",
      "type": "port",
      "description": "Auto-issue STOP when no command pending"
    }
  ],
  "ports_summary": {
    "i2c_master": [
      "clk",
      "rst",
      "s_axis_cmd_*",
      "s_axis_data_*",
      "m_axis_data_*",
      "scl_i/o/t",
      "sda_i/o/t",
      "busy",
      "missed_ack",
      "prescale[15:0]"
    ]
  },
  "usage_note": "prescale = clk_freq / (I2C_freq * 4). For 400 kHz I2C on 50 MHz clk: prescale = 31. Use tristate logic for open-drain SCL/SDA.",
  "tags": [
    "i2c",
    "serial",
    "communication",
    "master",
    "axi-stream"
  ],
  "verified": true,
  "verified_tools": [
    "Icarus Verilog"
  ],
  "added_date": "2026-06-21"
}